# Copy to project root as image.env (or .research_writer/image.env)
# Never commit real keys. Process env vars take precedence.
#
# MXM_GEN_IMAGE_URL must be the full images endpoint (not just the gateway host).
# If you set only https://api.example.com it will be auto-corrected to .../v1/images/generations

MXM_RESEARCH_APIKEY=tvly-your-tavily-key
MXM_GEN_IMAGE_KEY=your-image-api-key
MXM_GEN_IMAGE_URL=https://your-gateway.example/v1/images/generations
MXM_GEN_IMAGE_MODEL=gpt-image-2
MXM_GEN_IMAGE_SIZE=1024x1024
